{
  "expo": {
    "name": "RoxLive Form Lab",
    "slug": "roxlive-formlab",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "roxlive",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dsingson.roxliveformlab",
      "infoPlist": {
        "NSCameraUsageDescription": "RoxLive uses the camera to count reps and check form on-device.",
        "NSMicrophoneUsageDescription": "Optional: spoken voice commands during a set."
      }
    },
    "android": {
      "package": "com.dsingson.roxliveformlab",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "RoxLive uses the camera to count reps and check form on-device.",
          "enableFrameProcessors": true
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "34c4f494-0b47-4287-8201-6b419ff86bc8"
      }
    },
    "owner": "dsingson5"
  }
}
